{
  "name": "n8n-nodes-teable",
  "version": "0.1.0",
  "description": "n8n community node for Teable — manage records in a Teable base.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "teable"
  ],
  "license": "MIT",
  "homepage": "https://teable.io",
  "author": "Teable",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc && node scripts/copy-icons.mjs",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TeableApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Teable/Teable.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "n8n-workflow": "^1.66.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.0"
  }
}

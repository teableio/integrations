# Copy to `.env` and fill in. `zapier.tools.env.inject()` loads these in tests.
# `.env` is git-ignored — never commit real secrets.

# Your Teable instance ORIGIN — no trailing slash, no /api suffix.
# e.g. https://app.teable.io  or  https://xxxx.ngrok-free.app
TEABLE_INSTANCE_URL=https://app.teable.io

# OAuth2 client from Teable → Settings → OAuth Apps.
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# Optional: for the live jest tests, a valid access token (or a PAT — both are
# sent as a Bearer token) so tests can hit the API directly without the OAuth flow.
TEABLE_ACCESS_TOKEN=

# A base + table the token can read/write. Used by the live integration tests.
TEABLE_BASE_ID=bseXXXXXXXXXXXX
TEABLE_TABLE_ID=tblXXXXXXXXXXXX

# A text field name + an existing value in that table, for the Find Record test.
TEABLE_FIELD_NAME=Name
TEABLE_FIELD_VALUE=Acme
